import * as chromeLauncher from "chrome-launcher";
import lighthouse, { Config, RunnerResult } from "lighthouse";
import { LighthouseServiceConfig } from "../types/interfaces.js";
// import puppeteer from "puppeteer";
class LighthouseService {
  private url: string;

  constructor(url: string) {
    this.url = url;
  }
  async runTest(url: string): Promise<RunnerResult> {
    try {
      // const browser = await puppeteer.launch({
      //   headless: true,
      //   args: ["--remote-debugging-port=9222"],
      //   defaultViewport: null,
      // });
      const chrome = await chromeLauncher.launch({
        chromeFlags: ["--headless"],
        chromePath: "/home/a/.nix-profile/bin/google-chrome-stable",
      });
      // const browser = await puppeteer.launch({ headless: true });
      return await lighthouse(url, {
        port: chrome.port,
        output: "html",
        logLevel: "info",
      });
    } catch (e) {
      console.error(e);
      throw e;
    }
  }
}
export default LighthouseService;
